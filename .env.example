# The Graph hosted service was shut down in 2023.
# You need a free API key from https://thegraph.com/studio/
#
# Steps:
#   1. Go to https://thegraph.com/studio/
#   2. Sign in with your wallet (MetaMask etc.) or email
#   3. Copy your API key from the dashboard
#   4. Paste it below

GRAPH_API_KEY=your_api_key_here

# Optional: override the full subgraph URL if you want a different deployment
# SUBGRAPH_URL=https://gateway.thegraph.com/api/your_api_key_here/subgraphs/id/5zvR82QoaXYFyDEKLZ9t6v9adgnptxYpKpSbxtgVENFV
